{
  "name": "taxx",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "dev:backend:lan": "node scripts/run-backend-lan.mjs",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:frontend:fresh": "cd frontend && npm run dev:fresh",
    "dev:frontend:lan": "node scripts/run-frontend-lan.mjs",
    "dev:lan:info": "node scripts/lan-dev-info.mjs",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && python -m pip install -r requirements.txt",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start:frontend": "cd frontend && npm run start",
    "test:backend": "cd backend && python -m pytest",
    "test:frontend": "cd frontend && npx tsc --noEmit",
    "test": "npm run test:backend && npm run test:frontend",
    "validate:production": "cd backend && python scripts/validate_production_env.py --env-file .env.production",
    "validate:production:stripe": "cd backend && python scripts/validate_production_env.py --env-file .env.production --check-stripe",
    "bootstrap:production": "cd backend && python scripts/bootstrap_production.py",
    "bootstrap:staging": "cd backend && python scripts/bootstrap_production.py --staging-local",
    "staging:local": "node scripts/run-staging-local.mjs",
    "stripe:setup-catalog": "cd backend && python scripts/setup_stripe_catalog.py --env-file .env --write-env",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:staging:up": "docker compose -f docker-compose.staging.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "member:add": "cd backend && python scripts/seed_member_directory.py add",
    "mcp:install": "cd mcp-server && npm install",
    "mcp:build": "cd mcp-server && npm run build",
    "mcp:dev": "cd mcp-server && npm run dev"
  }
}
