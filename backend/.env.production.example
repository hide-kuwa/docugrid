# Copy to .env.production — never commit secrets.
# Used by: docker compose -f docker-compose.prod.yml
# Validate: python scripts/validate_production_env.py --env-file .env.production

DOCUGRID_ENV=production

# --- Required ---
DOCUGRID_JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_STRING
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
DOCUGRID_CORS_ORIGINS=https://app.example.com
DOCUGRID_FRONTEND_URL=https://app.example.com

DOCUGRID_ALLOW_HEADER_AUTH=false
DOCUGRID_ALLOW_PASSWORD_LOGIN=false
DOCUGRID_ALLOW_LOGIN_STAKEHOLDER_PICK=false

# --- Recommended ---
DOCUGRID_CSRF=true
# DOCUGRID_JWT_EXP_HOURS=24

# Localhost staging only (see docs/staging-local.md) — never on public hosts
# DOCUGRID_STAGING_LOCAL=true
# DOCUGRID_ALLOW_PASSWORD_LOGIN=true
# DOCUGRID_LOGIN_PASSWORD=staging

# --- Stripe (Phase 5 — enable when billing goes live) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FIRM_BASE=price_...
# STRIPE_PRICE_CLIENT_METERED=price_...
# STRIPE_PRICE_AI_TOPUP_100=price_...

# BILLING_FIRM_BASE_YEN=10000
# BILLING_FIRM_PER_CLIENT_YEN=100
# BILLING_PARTNER_COMMISSION_PERCENT=20
# AI_INCLUDED_TOKENS_PER_CLIENT_MONTH=25000
# AI_TOKENS_PER_100_YEN=10000
