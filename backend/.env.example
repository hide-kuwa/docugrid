# Copy to .env and adjust (never commit .env)

# development | production
DOCUGRID_ENV=development

# Required in production: random string, at least 32 characters
# DOCUGRID_JWT_SECRET=change-me-to-a-long-random-string

# Default true in development, false in production unless explicitly set
# DOCUGRID_ALLOW_HEADER_AUTH=true

# Google Sign-In (OAuth 2.0) — primary login in production
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized JavaScript origins: http://localhost:3000 (and your production URL)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Dev-only password login (disabled automatically in production)
# DOCUGRID_ALLOW_PASSWORD_LOGIN=true
# DOCUGRID_LOGIN_PASSWORD=password

# Optional
# DOCUGRID_JWT_EXP_HOURS=24
# DOCUGRID_TEMP_ADMIN_EMAIL=admin@tax.co.jp
# DOCUGRID_CORS_ORIGINS=http://localhost:3000,http://192.168.1.10:3000

# Stripe billing (事務所サブスクリプション + Connect + AI 従量)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FIRM_BASE=price_...          # 基本料 1万円/月
# STRIPE_PRICE_CLIENT_METERED=price_...     # 顧問先 100円/社/月（従量・Meter 連携）
# STRIPE_METER_CLIENT_EVENT=docugrid_billable_clients
# STRIPE_PRICE_AI_TOPUP_100=price_...       # AI 100円パック（任意・未設定時は動的 price_data）
# BILLING_FIRM_BASE_YEN=10000
# BILLING_FIRM_PER_CLIENT_YEN=100
# BILLING_PARTNER_COMMISSION_PERCENT=20
# AI_INCLUDED_TOKENS_PER_CLIENT_MONTH=25000
# AI_TOKENS_PER_100_YEN=10000
# DOCUGRID_FRONTEND_URL=http://localhost:3000
# DOCUGRID_CSRF=true
# DOCUGRID_MCP_JWT_EXP_HOURS=1
# DOCUGRID_MCP_TOKEN_RATE_LIMIT=10

# Moneytree LINK（銀行・クレカ連携）— 契約後にマネーツリーから client_id を取得
# MONEYTREE_LINK_CLIENT_ID=
# MONEYTREE_LINK_CLIENT_SECRET=
# MONEYTREE_LINK_REDIRECT_URI=http://localhost:8000/api/integrations/moneytree/callback
# MONEYTREE_LINK_ENV=staging
# MONEYTREE_LINK_MOCK=true

# --- Production template (copy to .env.production) ---
# See .env.production.example and docs/production-deployment.md
