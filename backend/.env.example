# Copy to .env and adjust (never commit .env)

# development | production
DOCUGRID_ENV=development

# Required in production: random string, at least 32 characters
# DOCUGRID_JWT_SECRET=change-me-to-a-long-random-string

# Default true in development, false in production unless explicitly set
# DOCUGRID_ALLOW_HEADER_AUTH=true

# Google Sign-In (OAuth 2.0) — primary login in production
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized JavaScript origins: http://localhost:3000 (and your production URL)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Dev-only password login (disabled automatically in production)
# DOCUGRID_ALLOW_PASSWORD_LOGIN=true
# DOCUGRID_LOGIN_PASSWORD=password

# Optional
# DOCUGRID_JWT_EXP_HOURS=24
# DOCUGRID_TEMP_ADMIN_EMAIL=admin@tax.co.jp
# DOCUGRID_CORS_ORIGINS=http://localhost:3000,http://192.168.1.10:3000
# DOCUGRID_CSRF=true
# DOCUGRID_LOGIN_RATE_LIMIT=20
# DOCUGRID_LOGIN_RATE_WINDOW_SEC=60
