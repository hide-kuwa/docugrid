# Example reverse proxy — TLS termination for DocuGrid API + optional frontend.
# Replace example.com with your domain. Requires Caddy 2.x.
#
#   caddy run --config deploy/Caddyfile

{
	email admin@example.com
}

# API
api.example.com {
	encode gzip
	reverse_proxy localhost:8000
}

# Frontend (if self-hosted Next.js instead of Vercel)
app.example.com {
	encode gzip
	reverse_proxy localhost:3000
}
