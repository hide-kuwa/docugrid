NEXT_PUBLIC_API_BASE=http://localhost:8000/api

# Same Wi-Fi sharing (run `npm run dev:frontend:lan` from repo root):
# NEXT_PUBLIC_API_BASE=http://192.168.x.x:8000/api

# Must match backend GOOGLE_OAUTH_CLIENT_ID (Web client ID from Google Cloud Console)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
