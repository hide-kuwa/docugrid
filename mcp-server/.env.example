# DocuGrid API base (no trailing slash on /api)
DOCUGRID_API_BASE=http://localhost:8000/api

# Auth — 本番・チーム利用では必ずユーザー本人の JWT を設定
DOCUGRID_ACCESS_TOKEN=

# 開発のみ: JWT 未設定時のパスワードログイン（共有 admin は非推奨）
DOCUGRID_EMAIL=admin@tax.co.jp
DOCUGRID_PASSWORD=password

# MCP セキュリティ（既定: strict=true, dev login=false）
DOCUGRID_MCP_STRICT=true
DOCUGRID_MCP_ALLOW_DEV_LOGIN=false

# 本番 API 接続時は DOCUGRID_ENV=production も推奨
# DOCUGRID_ENV=production

# 非推奨: 担当外 client をヘッダ固定しないこと（strict 時は visible と照合）
DOCUGRID_CLIENT_ID=
